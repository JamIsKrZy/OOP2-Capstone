<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.geometry.Insets?>

<StackPane styleClass="login-root" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pages.login.LoginController">

    <!-- Centered Card -->
    <HBox maxWidth="1100" maxHeight="700" styleClass="login-card">

        <!-- LEFT SIDE: FORM -->
        <VBox prefWidth="550" spacing="35" styleClass="login-left-pane" alignment="CENTER_LEFT">
            <!-- Logo Section -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <StackPane>
                    <Rectangle arcHeight="14.0" arcWidth="14.0" fill="#4f46e5" height="45.0" width="45.0" />
                    <Label text="TF" textFill="white" style="-fx-font-weight: bold; -fx-font-size: 18;"/>
                </StackPane>
                <VBox>
                    <Label text="TicketFlow" style="-fx-font-weight: bold; -fx-font-size: 22;"/>
                    <Label text="Issue Tracking Workspace" style="-fx-text-fill: #6b7280; -fx-font-size: 14;"/>
                </VBox>
            </HBox>

            <VBox spacing="12">
                <Label text="Connect &amp; Sync" styleClass="login-title"/>
                <Label text="Sign in with your Discord account to start managing tickets and collaborating with your team." styleClass="login-subtitle" wrapText="true"/>
            </VBox>

            <VBox spacing="20" alignment="CENTER_LEFT">
                <VBox spacing="8">
                    <Label text="Backend URL" styleClass="form-label"/>
                    <TextField fx:id="txtBaseUrl" promptText="http://localhost:8080/api" styleClass="text-input-field"/>
                </VBox>
                
                <Button text="Login with Discord" maxWidth="Infinity" styleClass="btn-discord" onAction="#handleLogin"/>
                <Label fx:id="lblStatus" text="Ready to authorize..." styleClass="waiting-label" visible="false"/>
                <Label fx:id="lblError" wrapText="true" styleClass="status-error" visible="false" managed="false"/>
            </VBox>

            <HBox alignment="CENTER_LEFT">
                <CheckBox fx:id="chkKeepLoggedIn" text="Remember this device" selected="true" style="-fx-text-fill: #4b5563; -fx-font-size: 14px;"/>
            </HBox>
        </VBox>

        <!-- RIGHT SIDE: BRANDING -->
        <VBox prefWidth="550" spacing="30" styleClass="login-right-pane" alignment="CENTER_LEFT">
            <Label text="FOR MODERN TEAMS" styleClass="teams-say"/>
            <Label text="&quot;TicketFlow brings Discord collaboration into a structured workspace.&quot;" styleClass="quote-label" wrapText="true"/>
            <Label text="Seamlessly bridge the gap between chat and code. Track every requirement and approval in one place." styleClass="quote-sub" wrapText="true"/>
        </VBox>

    </HBox>
</StackPane>