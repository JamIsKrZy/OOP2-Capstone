<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.text.Text?>
<?import javafx.geometry.Insets?>

<HBox prefHeight="800.0" prefWidth="1280.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pages.dashboard.MainController">

        <!-- SIDEBAR - FIXED -->
        <VBox minWidth="260.0" prefWidth="260.0" maxWidth="260.0" styleClass="sidebar">
            <HBox alignment="CENTER_LEFT" spacing="12">
                <padding><Insets top="10" right="20" bottom="30" left="20"/></padding>
                <ImageView fitWidth="120" fitHeight="40" preserveRatio="true">
                    <image>
                        <Image url="@icons/LOGO - Ticket Flow.png"/>
                    </image>
                </ImageView>
                <Label text="TicketFlow" textFill="white" style="-fx-font-weight: bold; -fx-font-size: 20px;"/>
            </HBox>

            <Label text="TICKETS" styleClass="nav-section-label"/>
            <Button fx:id="btnNavAvailable" text="Available Tickets" maxWidth="Infinity" styleClass="nav-button" onAction="#navAvailableTickets">
                <graphic>
                    <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                        <image>
                            <Image url="@icons/ICON - Available Tickets.png"/>
                        </image>
                    </ImageView>
                </graphic>
                <padding>
                    <Insets left="12"/>
                </padding>
            </Button>

            <VBox fx:id="adminReportsSection">
                <Label text="REPORTS" styleClass="nav-section-label"/>
                <Button fx:id="btnNavReports" text="Progress Reports" maxWidth="Infinity" styleClass="nav-button" onAction="#navReports">
                    <graphic>
                        <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                            <image>
                                <Image url="@icons/ICON - Progress Reports.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                    <padding>
                        <Insets left="12"/>
                    </padding>
                </Button>
            </VBox>
            <VBox fx:id="adminSystemSection">
                <Label text="SYSTEM" styleClass="nav-section-label"/>
                <Button fx:id="btnNavAdmin" text="Admin Panel" maxWidth="Infinity" styleClass="nav-button" onAction="#navAdminPanel">
                    <graphic>
                        <ImageView fitWidth="20" fitHeight="20" preserveRatio="true">
                            <image>
                                <Image url="@icons/ICON - Admin Panel.png"/>
                            </image>
                        </ImageView>
                    </graphic>
                    <padding>
                        <Insets left="12"/>
                    </padding>
                </Button>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="profile-box" onMouseClicked="#navProfile" style="-fx-cursor: hand;">
                <StackPane><Circle radius="18" fill="#1f2937"/><Text fx:id="sidebarAvatarText" text="AJ" fill="white" style="-fx-font-weight: bold;"/></StackPane>
                <VBox alignment="CENTER_LEFT"><Label fx:id="sidebarUserName" text="User" styleClass="profile-name"/><Label fx:id="sidebarUserRole" text="Role" styleClass="profile-role"/></VBox>
            </HBox>
        </VBox>

        <VBox HBox.hgrow="ALWAYS">
            <!-- TOP BAR -->
            <HBox alignment="CENTER_LEFT" styleClass="top-bar">
                <Label text="TicketFlow / " styleClass="breadcrumb-muted"/>
                <Label fx:id="lblBreadcrumbCurrent" text="Available Tickets" styleClass="breadcrumb-active"/>
                <Region HBox.hgrow="ALWAYS" />

                <HBox alignment="CENTER" spacing="20">
                    <!-- NOTIFICATION BUTTON -->

                    <VBox alignment="CENTER_RIGHT">
                        <Label fx:id="topbarUserName" text="User" style="-fx-font-weight: bold;"/>
                        <Label fx:id="topbarUserRole" text="Role" style="-fx-text-fill: #6b7280; -fx-font-size: 12px;"/>
                    </VBox>
                    <Button text="[-> Log out" styleClass="btn, btn-danger" onAction="#handleLogout"/>
                </HBox>
            </HBox>

            <!-- CENTER CONTENT AREA -->
            <StackPane fx:id="contentArea" VBox.vgrow="ALWAYS" style="-fx-padding: 30;"/>
        </VBox>
</HBox>